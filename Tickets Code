

total_cost = 0

# Ask for number of tickets with validation
while True:
    try:
        num_tickets = int(input("How many tickets do you want to purchase? "))
        break
    except ValueError:
        print("Please enter a valid number.")

# Loop through ticket holders
for i in range(num_tickets):
    while True:
        try:
            age = int(input(f"Enter the age of ticket holder #{i+1}: "))
            break
        except ValueError:
            print("Please enter a valid age.")

    if age < 3:
        price = 0
    elif age <= 12:
        price = 10
    else:
        price = 15

    total_cost += price

print("\nTotal cost of tickets: $" + str(total_cost))


